APP_NAME=Martelo Orçamentos V3
APP_ENV=development
LOG_LEVEL=INFO

DB_DRIVER=pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=martelo_orcamentos_v3
DB_USER=martelo_v3
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

# Optional override. If set, this value is used instead of the DB_* variables.
# DATABASE_URL=mysql+pymysql://martelo_v3:change-me@127.0.0.1:3306/martelo_orcamentos_v3?charset=utf8mb4

# Arquivo histórico Martelo V2 — usar obrigatoriamente um utilizador MySQL
# com permissões apenas SELECT. A aplicação bloqueia também comandos de escrita.
# Arquivo partilhado Martelo V2 — usar uma conta técnica limitada a SELECT e
# UPDATE na tabela de cabeçalho de orçamentos. A aplicação bloqueia INSERT,
# DELETE e alterações de esquema; o preço calculado pelo custeio também fica
# protegido na interface V3.
V2_DB_HOST=192.168.5.201
V2_DB_PORT=3306
V2_DB_NAME=orcamentos_v2
V2_DB_USER=martelo_v2_transicao
V2_DB_PASSWORD=change-me
# Alternativa completa:
# V2_DATABASE_URL=mysql+pymysql://martelo_v2_transicao:change-me@192.168.5.201:3306/orcamentos_v2?charset=utf8mb4
